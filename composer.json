{
    "name": "yourname/delivery-carrental",
    "version": "1.0.0",
    "description": "Delivery and CarRental classes with PHP",
    "type": "library",
    "require": {
        "php": "^8.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.64",
        "phpstan/phpstan": "^1.11"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "scripts": {
    "lint": "@php vendor/bin/php-cs-fixer fix --dry-run --diff",
    "lint-fix": "@php vendor/bin/php-cs-fixer fix",
    "analyse": "@php vendor/bin/phpstan analyse src --level=5",
    "test": "@php test.php",
    "simple-test": "@php simple-test.php",
    "check": [
        "@lint",
        "@analyse",
        "@test"
    ]
}
        
    }