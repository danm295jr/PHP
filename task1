<?php
function isSortedAscending($arr) {
    for ($i = 0; $i < count($arr) - 1; $i++) {
        if ($arr[$i] > $arr[$i + 1]) {
            return false;
        }
    }
    return true;
}

echo "Задача 1:\n";
$testArrays = [
    [1, 2, 3, 4, 5],
    [1, 3, 2, 4, 5],
    [5, 4, 3, 2, 1],
    [1, 1, 2, 3, 4]
];

foreach ($testArrays as $arr) {
    $result = isSortedAscending($arr) ? 'да' : 'нет';
    echo "Массив [" . implode(", ", $arr) . "] отсортирован: $result\n";
}
echo "\n";
?>
